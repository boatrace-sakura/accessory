    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "shimomo",
            "email": "developer@shimomo.net"
        }
    ],
    "require": {
        "php": "^8.0",
        "mck89/peast": "^1.0",
        "nesbot/carbon": "^2.0 || ^3.0",
        "php-di/php-di": "^6.0 || ^7.0",
        "symfony/browser-kit": "^6.0 || ^7.0",
        "symfony/css-selector": "^6.0 || ^7.0",
